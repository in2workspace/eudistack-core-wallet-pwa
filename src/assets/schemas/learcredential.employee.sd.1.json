{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LEAR Credential Employee V3 (dc+sd-jwt)",

  "credential_configuration_id": "learcredential.employee.sd.1",
  "credential_format": "dc+sd-jwt",
  "scope": "lear_credential_employee_sd_jwt",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://credentials.eudistack.eu/.well-known/credentials/lear_credential_employee/w3c/v3"
    ],
    "type": ["VerifiableCredential", "learcredential.employee.sd.1"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Employee (SD-JWT)",
        "locale": "en",
        "description": "Verifiable Credential for employees of an organization (Selective Disclosure JWT)"
      }
    ],
    "claims": [
      { "path": ["mandate", "mandatee", "firstName"], "display": [{ "name": "First Name", "locale": "en" }] },
      { "path": ["mandate", "mandatee", "lastName"],  "display": [{ "name": "Last Name",  "locale": "en" }] },
      { "path": ["mandate", "mandatee", "email"],     "display": [{ "name": "Email",      "locale": "en" }] },
      { "path": ["mandate", "mandator", "organizationIdentifier"], "display": [{ "name": "Organization", "locale": "en" }] },
      { "path": ["mandate", "power"], "display": [{ "name": "Powers", "locale": "en" }] }
    ]
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": true,
  "description": "Verifiable Credential for employees of an organization",
  "subject_extraction": {
    "strategy": "concat",
    "fields": ["mandatee.firstName", "mandatee.lastName"],
    "separator": " "
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandator.organizationIdentifier"
  },
  "sd_jwt": {
    "vct": "learcredential.employee.sd.1",
    "sd_alg": "sha-256",
    "sd_claims": ["mandate"]
  },
  "policy_extraction": {
    "powers_path": "mandate.power",
    "mandator_path": "mandate.mandator",
    "org_id_field": "organizationIdentifier"
  },
  "token_claims_mapping": {
    "id_token": {
      "given_name": "mandate.mandatee.firstName",
      "family_name": "mandate.mandatee.lastName",
      "email": "mandate.mandatee.email"
    },
    "access_token": {
      "tenant": "mandate.mandator.organizationIdentifier"
    },
    "scope": "openid learcredential"
  },
  "issuance_policy": {
    "policy_group": "lear_employee",
    "required_emitter_config_ids": [
      "learcredential.employee.w3c.4",
      "learcredential.employee.sd.1"
    ],
    "rules": ["RequireSignerIssuance", "RequireMandatorDelegation"],
    "delegation_function": "ProductOffering"
  },

  "type": "object",
  "required": ["mandate"],
  "additionalProperties": true,
  "properties": {
    "mandate": {
      "type": "object",
      "required": ["mandatee", "mandator", "power"],
      "additionalProperties": true,
      "properties": {
        "mandatee": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "employeeId": { "type": "string" },
            "email":      { "type": "string" },
            "firstName":  { "type": "string" },
            "lastName":   { "type": "string" }
          }
        },
        "mandator": {
          "type": "object",
          "required": ["organizationIdentifier"],
          "additionalProperties": true,
          "properties": {
            "commonName":             { "type": "string" },
            "country":                { "type": "string" },
            "email":                  { "type": "string" },
            "organization":           { "type": "string" },
            "organizationIdentifier": { "type": "string" },
            "serialNumber":           { "type": "string" }
          }
        },
        "power": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "action":   {},
              "domain":   { "type": "string" },
              "function": { "type": "string" },
              "type":     { "type": "string" }
            }
          }
        }
      }
    }
  }
}
