{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LEAR Credential Machine V2 (dc+sd-jwt)",

  "credential_configuration_id": "learcredential.machine.sd.1",
  "credential_format": "dc+sd-jwt",
  "scope": "lear_credential_machine_sd_jwt",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://credentials.eudistack.eu/.well-known/credentials/lear_credential_machine/w3c/v2"
    ],
    "type": ["VerifiableCredential", "learcredential.machine.sd.1"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Machine",
        "locale": "en",
        "description": "Verifiable Credential for machines"
      }
    ],
    "claims": [
      { "path": ["mandator", "commonName"],             "display": [{ "name": "Common Name", "locale": "en" }] },
      { "path": ["mandator", "country"],                "display": [{ "name": "Country", "locale": "en" }] },
      { "path": ["mandator", "email"],                  "display": [{ "name": "Email", "locale": "en" }] },
      { "path": ["mandator", "organization"],           "display": [{ "name": "Organization", "locale": "en" }] },
      { "path": ["mandator", "organizationIdentifier"], "display": [{ "name": "Organization ID", "locale": "en" }] },
      { "path": ["mandator", "serialNumber"],           "display": [{ "name": "Serial Number", "locale": "en" }] },
      { "path": ["mandatee", "serviceId"],              "display": [{ "name": "Service ID", "locale": "en" }] },
      { "path": ["mandatee", "domain"],                 "display": [{ "name": "Domain", "locale": "en" }] },
      { "path": ["mandatee", "ipAddress"],              "display": [{ "name": "IP Address", "locale": "en" }] },
      { "path": ["power"],                              "display": [{ "name": "Powers", "locale": "en" }] }
    ],
    "summary_claims": [
      ["mandatee", "serviceId"],
      ["mandatee", "domain"],
      ["mandatee", "ipAddress"]
    ]
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": true,
  "description": "Verifiable Credential for machines",
  "subject_extraction": {
    "strategy": "field",
    "fields": ["mandatee.domain"],
    "separator": null
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandator.organizationIdentifier"
  },
  "credential_subject_strategy": "direct",
  "sd_jwt": {
    "vct": "learcredential.machine.sd.1",
    "sd_alg": "sha-256",
    "sd_claims": ["mandatee", "mandator", "power"]
  },
  "policy_extraction": {
    "powers_path": "power",
    "mandator_path": "mandator",
    "org_id_field": "organizationIdentifier"
  },
  "token_claims_mapping": {
    "subject_paths": ["mandatee.ipAddress", "mandatee.domain"],
    "access_token": {
      "tenant": "mandator.organizationIdentifier"
    },
    "id_token_embed": {
      "mandatee": "mandatee",
      "mandator": "mandator",
      "power": "power"
    },
    "access_token_embed": {
      "mandatee": "mandatee",
      "mandator": "mandator",
      "power": "power"
    },
    "scope": "machine learcredential"
  },
  "issuance_policy": {
    "policy_group": "lear_machine",
    "required_emitter_config_ids": [
      "learcredential.employee.w3c.4",
      "learcredential.employee.sd.1"
    ],
    "rules": ["RequireSignerIssuance", "RequireMandatorDelegation"],
    "delegation_function": "Onboarding"
  },

  "type": "object",
  "required": ["mandatee", "mandator", "power"],
  "additionalProperties": true,
  "properties": {
    "mandatee": {
      "type": "object",
      "required": ["ipAddress"],
      "additionalProperties": true,
      "properties": {
        "serviceId": { "type": "string" },
        "domain":    { "type": "string" },
        "ipAddress": { "type": "string" }
      }
    },
    "mandator": {
      "type": "object",
      "required": ["organizationIdentifier"],
      "additionalProperties": true,
      "properties": {
        "commonName":             { "type": "string" },
        "country":                { "type": "string" },
        "email":                  { "type": "string" },
        "organization":           { "type": "string" },
        "organizationIdentifier": { "type": "string" },
        "serialNumber":           { "type": "string" }
      }
    },
    "power": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "action":   {},
          "domain":   { "type": "string" },
          "function": { "type": "string" },
          "type":     { "type": "string" }
        }
      }
    }
  }
}
