{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gaia-X Label Credential V1 (jwt_vc_json)",

  "credential_configuration_id": "gx.labelcredential.w3c.1",
  "credential_format": "jwt_vc_json",
  "scope": "gx_label_credential",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://w3id.org/gaia-x/development#"
    ],
    "type": ["VerifiableCredential", "gx.labelcredential.w3c.1"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "credential_metadata": {
    "display": [
      {
        "name": "Gaia-X Label Credential",
        "locale": "en",
        "description": "Gaia-X compliance label for cloud services"
      },
      {
        "name": "Credencial Etiqueta Gaia-X",
        "locale": "es",
        "description": "Etiqueta de conformidad Gaia-X para servicios cloud"
      },
      {
        "name": "Credencial Etiqueta Gaia-X",
        "locale": "ca",
        "description": "Etiqueta de conformitat Gaia-X per a serveis cloud"
      }
    ],
    "claims": [
      { "path": ["credentialSubject", "id"],                      "display": [{ "name": "ID", "locale": "en" }, { "name": "ID", "locale": "es" }, { "name": "ID", "locale": "ca" }] },
      { "path": ["credentialSubject", "gx:labelLevel"],           "display": [{ "name": "Label Level", "locale": "en" }, { "name": "Nivel de Etiqueta", "locale": "es" }, { "name": "Nivell d'Etiqueta", "locale": "ca" }], "value_map": { "BL": "Baseline", "P": "Professional", "P+": "Professional Plus" } },
      { "path": ["credentialSubject", "gx:engineVersion"],        "display": [{ "name": "Engine Version", "locale": "en" }, { "name": "Versión del Motor", "locale": "es" }, { "name": "Versió del Motor", "locale": "ca" }] },
      { "path": ["credentialSubject", "gx:rulesVersion"],         "display": [{ "name": "Rules Version", "locale": "en" }, { "name": "Versión de Reglas", "locale": "es" }, { "name": "Versió de Regles", "locale": "ca" }] },
      { "path": ["credentialSubject", "gx:compliantCredentials"], "display": [{ "name": "Compliant Credentials", "locale": "en" }, { "name": "Credenciales Conformes", "locale": "es" }, { "name": "Credencials Conformes", "locale": "ca" }] },
      { "path": ["credentialSubject", "gx:validatedCriteria"],    "display": [{ "name": "Validated Criteria", "locale": "en" }, { "name": "Criterios Validados", "locale": "es" }, { "name": "Criteris Validats", "locale": "ca" }] }
    ],
    "summary_claims": [
      ["credentialSubject", "gx:labelLevel"],
      ["credentialSubject", "gx:engineVersion"],
      ["credentialSubject", "gx:rulesVersion"]
    ]
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": false,
  "description": "Gaia-X compliance label for cloud services",
  "subject_extraction": {
    "strategy": "field",
    "field": "id"
  },
  "organization_extraction": {
    "strategy": "none"
  },
  "policy_extraction": null,
  "token_claims_mapping": {
    "subject_paths": ["credentialSubject.id"],
    "access_token": {},
    "scope": "gx_label_credential"
  },
  "issuance_policy": {
    "policy_group": "label_credential",
    "required_emitter_config_ids": [
      "learcredential.machine.w3c.3",
      "learcredential.machine.sd.1"
    ],
    "rules": ["RequireCertificationIssuance"]
  },

  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "additionalProperties": true,
  "properties": {
    "@context": { "type": "array", "items": { "type": "string" } },
    "id": { "type": "string" },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "allOf": [
        { "contains": { "const": "VerifiableCredential" } },
        { "contains": { "const": "gx.labelcredential.w3c.1" } }
      ]
    },
    "issuer": { "type": "string", "pattern": "^did:" },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "gx:labelLevel", "gx:engineVersion", "gx:rulesVersion", "gx:compliantCredentials", "gx:validatedCriteria"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "gx:labelLevel": {
          "type": "string",
          "enum": ["BL", "P", "P+"]
        },
        "gx:engineVersion": { "type": "string" },
        "gx:rulesVersion": { "type": "string" },
        "gx:compliantCredentials": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "gx:digestSRI"],
            "additionalProperties": true,
            "properties": {
              "id":   { "type": "string" },
              "type": { "type": "string" },
              "gx:digestSRI": { "type": "string", "pattern": "^sha256-" }
            }
          }
        },
        "gx:validatedCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "format": "uri" }
        }
      }
    },
    "issuanceDate":    { "type": "string", "format": "date-time" },
    "validFrom":       { "type": "string", "format": "date-time" },
    "validUntil":      { "type": "string", "format": "date-time" },
    "expirationDate":  { "type": "string", "format": "date-time" },
    "credentialStatus": {
      "type": "object",
      "required": ["type", "statusPurpose", "statusListIndex", "statusListCredential"],
      "additionalProperties": true,
      "properties": {
        "id":                   { "type": "string", "format": "uri" },
        "type":                 { "type": "string" },
        "statusPurpose":        { "type": "string", "enum": ["revocation", "suspension", "refresh", "message"] },
        "statusListIndex":      { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    }
  }
}
