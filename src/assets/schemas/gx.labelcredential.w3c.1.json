{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gaia-X Label Credential V1 (jwt_vc_json)",

  "credential_configuration_id": "gx.labelcredential.w3c.1",
  "credential_format": "jwt_vc_json",
  "scope": "gx_label_credential",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://w3id.org/gaia-x/development#"
    ],
    "type": ["VerifiableCredential", "gx.labelcredential.w3c.1"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": false,
  "issuance_policy": {
    "policy_group": "label_credential",
    "required_emitter_config_ids": [
      "learcredential.machine.w3c.3",
      "learcredential.machine.sd.1"
    ],
    "rules": ["RequireCertificationIssuance"]
  },

  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "additionalProperties": true,
  "properties": {
    "@context": { "type": "array", "items": { "type": "string" } },
    "id": { "type": "string" },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "allOf": [
        { "contains": { "const": "VerifiableCredential" } },
        { "contains": { "const": "gx.labelcredential.w3c.1" } }
      ]
    },
    "issuer": { "type": "string", "pattern": "^did:" },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "gx:labelLevel", "gx:engineVersion", "gx:rulesVersion", "gx:compliantCredentials", "gx:validatedCriteria"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "gx:labelLevel": {
          "type": "string",
          "enum": ["BL", "P", "P+"]
        },
        "gx:engineVersion": { "type": "string" },
        "gx:rulesVersion": { "type": "string" },
        "gx:compliantCredentials": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "gx:digestSRI"],
            "additionalProperties": true,
            "properties": {
              "id":   { "type": "string" },
              "type": { "type": "string" },
              "gx:digestSRI": { "type": "string", "pattern": "^sha256-" }
            }
          }
        },
        "gx:validatedCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "format": "uri" }
        }
      }
    },
    "issuanceDate":    { "type": "string", "format": "date-time" },
    "validFrom":       { "type": "string", "format": "date-time" },
    "validUntil":      { "type": "string", "format": "date-time" },
    "expirationDate":  { "type": "string", "format": "date-time" },
    "credentialStatus": {
      "type": "object",
      "required": ["type", "statusPurpose", "statusListIndex", "statusListCredential"],
      "additionalProperties": true,
      "properties": {
        "id":                   { "type": "string", "format": "uri" },
        "type":                 { "type": "string" },
        "statusPurpose":        { "type": "string", "enum": ["revocation", "suspension", "refresh", "message"] },
        "statusListIndex":      { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    }
  }
}
