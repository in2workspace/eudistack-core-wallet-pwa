{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LEAR Credential Employee V4 (jwt_vc_json)",

  "credential_configuration_id": "learcredential.employee.w3c.1",
  "credential_format": "jwt_vc_json",
  "scope": "lear_credential_employee",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://credentials.eudistack.eu/.well-known/credentials/lear_credential_employee/w3c/v3"
    ],
    "type": ["VerifiableCredential", "learcredential.employee.w3c.1"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Employee",
        "locale": "en",
        "description": "Verifiable Credential for employees of an organization"
      },
      {
        "name": "Credencial LEAR Empleado",
        "locale": "es",
        "description": "Credencial Verificable para empleados de una organización"
      },
      {
        "name": "Credencial LEAR Empleat",
        "locale": "ca",
        "description": "Credencial Verificable per a empleats d'una organització"
      }
    ],
    "claims": [
      { "path": ["credentialSubject", "mandate", "mandator", "commonName"],             "display": [{ "name": "Common Name", "locale": "en" }, { "name": "Nombre Común", "locale": "es" }, { "name": "Nom Comú", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "country"],                "display": [{ "name": "Country", "locale": "en" }, { "name": "País", "locale": "es" }, { "name": "País", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "email"],                  "display": [{ "name": "Email", "locale": "en" }, { "name": "Correo Electrónico", "locale": "es" }, { "name": "Correu Electrònic", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "organization"],           "display": [{ "name": "Organization", "locale": "en" }, { "name": "Organización", "locale": "es" }, { "name": "Organització", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "organizationIdentifier"], "display": [{ "name": "Organization ID", "locale": "en" }, { "name": "ID de Organización", "locale": "es" }, { "name": "ID d'Organització", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "serialNumber"],           "display": [{ "name": "Serial Number", "locale": "en" }, { "name": "Número de Serie", "locale": "es" }, { "name": "Número de Sèrie", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandatee", "employeeId"],             "display": [{ "name": "Employee ID", "locale": "en" }, { "name": "ID de Empleado", "locale": "es" }, { "name": "ID d'Empleat", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandatee", "email"],                  "display": [{ "name": "Email", "locale": "en" }, { "name": "Correo Electrónico", "locale": "es" }, { "name": "Correu Electrònic", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandatee", "firstName"],              "display": [{ "name": "First Name", "locale": "en" }, { "name": "Nombre", "locale": "es" }, { "name": "Nom", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "mandatee", "lastName"],               "display": [{ "name": "Last Name", "locale": "en" }, { "name": "Apellido", "locale": "es" }, { "name": "Cognom", "locale": "ca" }] },
      { "path": ["credentialSubject", "mandate", "power"],                              "display": [{ "name": "Powers", "locale": "en" }, { "name": "Poderes", "locale": "es" }, { "name": "Poders", "locale": "ca" }] }
    ],
    "summary_claims": [
      ["credentialSubject", "mandate", "mandatee", "firstName"],
      ["credentialSubject", "mandate", "mandatee", "lastName"],
      ["credentialSubject", "mandate", "mandatee", "email"]
    ]
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": true,
  "description": "Verifiable Credential for employees of an organization",
  "subject_extraction": {
    "strategy": "concat",
    "fields": ["mandatee.firstName", "mandatee.lastName"],
    "separator": " "
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandator.organizationIdentifier"
  },
  "policy_extraction": {
    "powers_path": "credentialSubject.mandate.power",
    "mandator_path": "credentialSubject.mandate.mandator",
    "org_id_field": "organizationIdentifier"
  },
  "token_claims_mapping": {
    "subject_paths": ["credentialSubject.mandate.mandatee.email"],
    "id_token": {
      "given_name": "credentialSubject.mandate.mandatee.firstName",
      "family_name": "credentialSubject.mandate.mandatee.lastName",
      "email": "credentialSubject.mandate.mandatee.email",
      "name": {
        "strategy": "concat",
        "paths": ["credentialSubject.mandate.mandatee.firstName", "credentialSubject.mandate.mandatee.lastName"],
        "separator": " "
      },
      "email_verified": { "strategy": "constant", "value": true }
    },
    "access_token": {
      "tenant": "credentialSubject.mandate.mandator.organizationIdentifier"
    },
    "id_token_embed": {
      "mandatee": "credentialSubject.mandate.mandatee",
      "mandator": "credentialSubject.mandate.mandator",
      "power": "credentialSubject.mandate.power"
    },
    "access_token_embed": {
      "mandatee": "credentialSubject.mandate.mandatee",
      "mandator": "credentialSubject.mandate.mandator",
      "power": "credentialSubject.mandate.power"
    },
    "scope": "openid learcredential"
  },
  "issuance_policy": {
    "policy_group": "lear_employee",
    "required_emitter_config_ids": [
      "learcredential.employee.w3c.1",
      "learcredential.employee.sd.1"
    ],
    "rules": ["RequireSignerIssuance", "RequireMandatorDelegation"],
    "delegation_function": "ProductOffering"
  },

  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "additionalProperties": true,
  "properties": {
    "@context": { "type": "array", "items": { "type": "string" } },
    "id": { "type": "string" },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "allOf": [
        { "contains": { "const": "VerifiableCredential" } },
        { "contains": { "const": "learcredential.employee.w3c.1" } }
      ]
    },
    "description": { "type": "string" },
    "issuer": {
      "type": "object",
      "required": ["id", "organizationIdentifier"],
      "additionalProperties": true,
      "properties": {
        "id":                     { "type": "string", "format": "uri" },
        "organizationIdentifier": { "type": "string" },
        "organization":           { "type": "string" },
        "country":                { "type": "string" },
        "commonName":             { "type": "string" },
        "serialNumber":           { "type": "string" }
      }
    },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "mandate"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "mandate": {
          "type": "object",
          "required": ["mandatee", "mandator", "power"],
          "additionalProperties": true,
          "properties": {
            "mandatee": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "employeeId": { "type": ["string", "null"] },
                "email":      { "type": "string" },
                "firstName":  { "type": "string" },
                "lastName":   { "type": "string" }
              }
            },
            "mandator": {
              "type": "object",
              "required": ["organizationIdentifier"],
              "additionalProperties": true,
              "properties": {
                "commonName":             { "type": "string" },
                "country":                { "type": "string" },
                "email":                  { "type": "string" },
                "organization":           { "type": "string" },
                "organizationIdentifier": { "type": "string" },
                "serialNumber":           { "type": "string" }
              }
            },
            "power": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "action":   {},
                  "domain":   { "type": "string" },
                  "function": { "type": "string" },
                  "type":     { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "credentialStatus": {
      "type": "object",
      "required": ["type", "statusPurpose", "statusListIndex", "statusListCredential"],
      "additionalProperties": true,
      "properties": {
        "id":                   { "type": "string", "format": "uri" },
        "type":                 { "const": "BitstringStatusListEntry" },
        "statusPurpose":        { "type": "string", "enum": ["revocation", "suspension", "refresh", "message"] },
        "statusListIndex":      { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    },
    "validFrom":  { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" }
  }
}
