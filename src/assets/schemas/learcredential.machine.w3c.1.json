{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LEAR Credential Machine V2 (jwt_vc_json)",

  "credential_configuration_id": "learcredential.machine.w3c.1",
  "credential_format": "jwt_vc_json",
  "scope": "lear_credential_machine",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://credentials.eudistack.eu/.well-known/credentials/lear_credential_machine/w3c/v2"
    ],
    "type": ["VerifiableCredential", "learcredential.machine.w3c.1"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Machine",
        "locale": "en",
        "description": "Verifiable Credential for machines"
      }
    ],
    "claims": [
      { "path": ["credentialSubject", "mandate", "mandatee", "domain"],    "display": [{ "name": "Domain",     "locale": "en" }] },
      { "path": ["credentialSubject", "mandate", "mandatee", "ipAddress"], "display": [{ "name": "IP Address", "locale": "en" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "organizationIdentifier"], "display": [{ "name": "Organization", "locale": "en" }] },
      { "path": ["credentialSubject", "mandate", "power"], "display": [{ "name": "Powers", "locale": "en" }] }
    ]
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": true,
  "description": "Verifiable Credential for machines",
  "subject_extraction": {
    "strategy": "field",
    "fields": ["mandatee.domain"],
    "separator": null
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandator.organizationIdentifier"
  },
  "policy_extraction": {
    "powers_path": "credentialSubject.mandate.power",
    "mandator_path": "credentialSubject.mandate.mandator",
    "org_id_field": "organizationIdentifier"
  },
  "token_claims_mapping": {
    "access_token": {
      "tenant": "credentialSubject.mandate.mandator.organizationIdentifier"
    },
    "scope": "machine learcredential"
  },
  "issuance_policy": {
    "policy_group": "lear_machine",
    "required_emitter_config_ids": [
      "learcredential.employee.w3c.4",
      "learcredential.employee.sd.1"
    ],
    "rules": ["RequireSignerIssuance", "RequireMandatorDelegation"],
    "delegation_function": "Onboarding"
  },

  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "additionalProperties": true,
  "properties": {
    "@context": { "type": "array", "items": { "type": "string" } },
    "id": { "type": "string" },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "allOf": [
        { "contains": { "const": "VerifiableCredential" } },
        { "contains": { "const": "learcredential.machine.w3c.1" } }
      ]
    },
    "issuer": {
      "type": "object",
      "required": ["id", "organizationIdentifier"],
      "additionalProperties": true,
      "properties": {
        "id":                     { "type": "string", "format": "uri" },
        "organizationIdentifier": { "type": "string" },
        "organization":           { "type": "string" },
        "country":                { "type": "string" },
        "commonName":             { "type": "string" },
        "serialNumber":           { "type": "string" }
      }
    },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "mandate"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "mandate": {
          "type": "object",
          "required": ["mandatee", "mandator", "power"],
          "additionalProperties": true,
          "properties": {
            "mandatee": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "domain":    { "type": "string" },
                "ipAddress": { "type": "string" }
              }
            },
            "mandator": {
              "type": "object",
              "required": ["organizationIdentifier"],
              "additionalProperties": true,
              "properties": {
                "commonName":             { "type": "string" },
                "country":                { "type": "string" },
                "email":                  { "type": "string" },
                "organization":           { "type": "string" },
                "organizationIdentifier": { "type": "string" },
                "serialNumber":           { "type": "string" }
              }
            },
            "power": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "action":   {},
                  "domain":   { "type": "string" },
                  "function": { "type": "string" },
                  "type":     { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "credentialStatus": {
      "type": "object",
      "required": ["type", "statusPurpose", "statusListIndex", "statusListCredential"],
      "additionalProperties": true,
      "properties": {
        "id":                   { "type": "string", "format": "uri" },
        "type":                 { "const": "BitstringStatusListEntry" },
        "statusPurpose":        { "type": "string", "enum": ["revocation", "suspension", "refresh", "message"] },
        "statusListIndex":      { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    },
    "validFrom":  { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" }
  }
}
